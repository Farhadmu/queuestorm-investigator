# QueueStorm Investigator Environment Variables Example
# Copy this file to .env and fill in the values

# API Key for Google Gemini (Recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for OpenAI (Optional Fallback)
# OPENAI_API_KEY=your_openai_api_key_here

# Port to bind the server to (Default is 8000)
PORT=8000
